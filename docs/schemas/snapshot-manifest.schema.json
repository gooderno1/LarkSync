{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://larksync.local/schemas/snapshot-manifest.schema.json",
  "title": "LarkSync snapshot manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format_version",
    "exported_at",
    "source_database",
    "snapshot_database",
    "schema_version",
    "integrity_check",
    "table_counts",
    "redaction_rules"
  ],
  "properties": {
    "format_version": { "const": 1 },
    "exported_at": { "type": "number" },
    "source_database": { "type": "string", "minLength": 1 },
    "snapshot_database": { "type": "string", "minLength": 1 },
    "schema_version": { "type": ["integer", "null"], "minimum": 0 },
    "integrity_check": { "const": "ok" },
    "table_counts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "redaction_rules": {
      "type": "object",
      "required": ["tasks", "running_runs", "tokens", "owner_open_id", "conflict_previews", "paths", "credentials"],
      "additionalProperties": { "type": "string" }
    }
  }
}
